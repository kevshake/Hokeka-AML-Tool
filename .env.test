# HOKEKA Fraud Detector Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================
DATABASE_URL=jdbc:postgresql://postgres:5432/fraud_detector
DATABASE_USERNAME=fraud_user
DATABASE_PASSWORD=WfVCbdzwivK+UEVQqwBoeH5adw8AVWDKmt9yssz/Rjc=

# =============================================================================
# AEROSPIKE CACHE CONFIGURATION (Required)
# =============================================================================
AEROSPIKE_HOSTS=aerospike:3000
AEROSPIKE_NAMESPACE=fraud_detector

# =============================================================================
# SECURITY CONFIGURATION (Required)
# =============================================================================
# 32-byte hexadecimal encryption key for PII data
# Generate with: openssl rand -hex 32
SECURITY_ENCRYPTION_KEY=f7e825211b39c80bca9ab4fbe0de30a49916b6c030f054ca514ee653b4d4f468

# =============================================================================
# CORS CONFIGURATION (Required)
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://hokeka.com

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
SERVER_PORT=2637
SPRING_PROFILES_ACTIVE=test

